+
+	"github.com/casbin/casbin/v2"
+	"github.com/casbin/redis-adapter/v3"
+	"github.com/gomodule/redigo/redis"
+)
+
+func main() {
+	fmt.Println("Redis Adapter Examples")
+	fmt.Println("======================")
+
+	// Example 1: Basic configuration
+	fmt.Println("\n1. Basic Configuration:")
+	config := &redisadapter.Config{
+		Network: "tcp",
+		Address: "127.0.0.1:6379",
+	}
+	a, err := redisadapter.NewAdapter(config)
+	if err != nil {
+		log.Printf("Failed to create adapter: %v", err)
+		return
+	}
+	
+	e, err := casbin.NewEnforcer("rbac_model.conf", a)
+	if err != nil {
+		log.Printf("Failed to create enforcer: %v", err)
+		return
+	}
+	
+	fmt.Printf("Adapter created successfully with key: %s\n", config.Key)
+	
+	// Example 2: Configuration with authentication
+	fmt.Println("\n2. Configuration with Authentication:")
+	config = &redisadapter.Config{
+		Network:  "tcp",
+		Address:  "127.0.0.1:6379",
+		Username: "myuser",
+		Password: "mypassword",
+		Key:      "auth_casbin_rules",
+	}
+	a, err = redisadapter.NewAdapter(config)
+	if err != nil {
+		log.Printf("Failed to create adapter with auth: %v", err)
+		// This is expected if Redis doesn't have authentication configured
+	} else {
+		fmt.Printf("Adapter with authentication created successfully\n")
+	}
+	
+	// Example 3: Configuration with custom key and TLS
+	fmt.Println("\n3. Configuration with Custom Key and TLS:")
+	config = &redisadapter.Config{
+		Network: "tcp",
+		Address: "127.0.0.1:6379",
+		Key:     "my_custom_casbin_rules",
+		TLSConfig: &tls.Config{
+			InsecureSkipVerify: true, // For testing only
+		},
+	}
+	a, err = redisadapter.NewAdapter(config)
+	if err != nil {
+		log.Printf("Failed to create adapter with TLS: %v", err)
+		// This is expected if Redis doesn't support TLS
+	} else {
+		fmt.Printf("Adapter with TLS created successfully\n")
+	}
+	
+	// Example 4: Configuration with connection pool
+	fmt.Println("\n4. Configuration with Connection Pool:")
+	pool := &redis.Pool{
+		MaxIdle:     3,
+		MaxActive:   5,
+		IdleTimeout: 240 * time.Second,
+		Dial: func() (redis.Conn, error) {
+			return redis.Dial("tcp", "127.0.0.1:6379")
+		},
+	}
+	config = &redisadapter.Config{
+		Pool: pool,
+		Key:  "pooled_casbin_rules",
+	}
+	a, err = redisadapter.NewAdapter(config)
+	if err != nil {
+		log.Printf("Failed to create adapter with pool: %v", err)
+		return
+	}
+	
+	e, err = casbin.NewEnforcer("rbac_model.conf", a)
+	if err != nil {
+		log.Printf("Failed to create enforcer with pooled adapter: %v", err)
+		return
+	}
+	
+	fmt.Printf("Adapter with connection pool created successfully\n")
+	
+	// Example 5: Basic operations
+	fmt.Println("\n5. Basic Operations:")
+	
+	// Add some policies
+	e.AddPolicy("alice", "data1", "read")
+	e.AddPolicy("bob", "data2", "write")
+	e.AddPolicy("charlie", "data3", "read")
+	
+	// Save policies to Redis
+	err = e.SavePolicy()
+	if err != nil {
+		log.Printf("Failed to save policy: %v", err)
+		return
+	}
+	fmt.Println("Policies saved to Redis")
+	
+	// Load policies from Redis
+	err = e.LoadPolicy()
+	if err != nil {
+		log.Printf("Failed to load policy: %v", err)
+		return
+	}
+	fmt.Println("Policies loaded from Redis")
+	
+	// Check permissions
+	fmt.Println("\nPermission checks:")
+	fmt.Printf("alice can read data1: %v\n", e.Enforce("alice", "data1", "read"))
+	fmt.Printf("alice can write data1: %v\n", e.Enforce("alice", "data1", "write"))
+	fmt.Printf("bob can write data2: %v\n", e.Enforce("bob", "data2", "write"))
+	fmt.Printf("charlie can read data3: %v\n", e.Enforce("charlie", "data3", "read"))
+	
+	// Display current policies
+	fmt.Println("\nCurrent policies:")
+	policies := e.GetPolicy()
+	for _, policy := range policies {
+		fmt.Printf("  %v\n", policy)
+	}
+	
+	fmt.Println("\nExample completed successfully!")
+}
